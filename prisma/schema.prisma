generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
}

model Club {
 id        String   @id @default(uuid())
 name      String
 city      String
 state     String
 country   String
 createdAt DateTime @default(now())

 courts Court[]
 users  User[]
}

model User {
 id        String   @id @default(uuid())
 name      String
 email     String   @unique
 password  String
 experienceLevel String
 city      String
 state     String

 clubId String
 club   Club @relation(fields: [clubId], references: [id])

 createdAt DateTime @default(now())
}

model Court {
 id        String @id @default(uuid())
 name      String
 price     Float

 clubId String
 club   Club @relation(fields: [clubId], references: [id])
}

model Reservation {
 id        String   @id @default(uuid())

 userId String
 courtId String

 date DateTime
 startTime String
 endTime String

 totalPrice Float
 status String

 createdAt DateTime @default(now())
}